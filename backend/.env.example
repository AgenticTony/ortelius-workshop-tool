# Copy this file to .env and fill in your values
# Never commit the real .env file to GitHub

APP_NAME=Workshop Tool API

# Deployment tier: dev | test | production.
# In "production" the app fails fast at boot if DATABASE_URL / CLAUDE_API_KEY
# are missing and rejects wildcard CORS — set this in your prod host env.
APP_ENV=dev
# Debug must be opt-in. Leave false unless actively debugging.
DEBUG=false

HOST=127.0.0.1
PORT=8000

# Comma-separated list of allowed CORS origins.
# Use the Flutter web URL in production. "*" is allowed for local dev only and
# is rejected at boot when APP_ENV=production.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_BASE_URL=https://api.anthropic.com
# Model for idea clustering (claude-sonnet-4-5-20250929 by default; change if
# Anthropic retires this dated ID).
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Supabase — get these from supabase.com → your project → Settings → Database
# The URL looks like: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=your-supabase-database-url-here
