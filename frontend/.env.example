# Frontend environment config. Copy to .env and adjust.
#
# API_BASE_URL is the *explicit* API base URL. If set, it always wins — use it
# for production (bake it into the Docker build via the API_BASE_URL build arg)
# and for non-web mobile dev (e.g. http://192.168.x.x:8000).
#
# If API_BASE_URL is empty/absent, the web build falls back to deriving the API
# from the browser origin + :8000 (handy for local web dev where the frontend
# runs on :7355 and the API on :8000 of the same host).
API_BASE_URL=http://localhost:8000
